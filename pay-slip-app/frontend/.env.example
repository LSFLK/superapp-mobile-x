# Pay Slip App Environment Variables

# Development token for testing when not in super app
# Can be `admin-token` (admin) or `user-token`/`john-token` (regular users)
# These tokens are valid when running the local mock server (npm run mock)
VITE_DEV_TOKEN=admin-token

# API Base URL (optional, defaults to /api in production, localhost:3001/api in dev)
# VITE_API_BASE=https://your-backend-api.com/api

# Proxy target for development (optional)
# VITE_PROXY_TARGET=http://localhost:8080
